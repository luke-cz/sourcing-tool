# Required: Claude API for AI summaries
ANTHROPIC_API_KEY=sk-ant-...

# Recommended: Raises GitHub rate limit from 10 to 30 req/min
# Create at https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=ghp_...

# LinkedIn search via Brave Search API ($5 free credits/month = ~1000 searches)
# Sign up at https://api.search.brave.com
BRAVE_SEARCH_KEY=

# Optional: LinkedIn search via Google Custom Search Engine (legacy)
# 1. Create a CSE at https://programmablesearchengine.google.com/
# 2. Add "linkedin.com/in/*" as the site to search
# 3. Get a Google API key at https://console.cloud.google.com/ (Custom Search API)
# Free tier: 100 queries/day
GOOGLE_CSE_API_KEY=AIza...
GOOGLE_CSE_ID=...

# Optional: Stack Overflow (raises limit from 300 to 10,000 req/day)
# Register an app at https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=...
